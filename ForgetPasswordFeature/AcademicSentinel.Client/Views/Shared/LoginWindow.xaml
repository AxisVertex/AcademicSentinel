<Window x:Class="AcademicSentinel.Client.Views.Shared.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="FourCUDA - Login"
        Height="640" Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseDown"
        Background="Transparent"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <!-- ====================== FEU TECH COLORS ====================== -->
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>
        <Color x:Key="FEUGold">#FFB300</Color>
        <Color x:Key="FEUGoldLight">#FFD54F</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="{StaticResource FEUGold}"/>
        <SolidColorBrush x:Key="FEUGoldLightBrush" Color="{StaticResource FEUGoldLight}"/>

        <!-- ====================== TEXT INPUT STYLE ====================== -->
        <Style x:Key="LoginTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================== PASSWORD INPUT STYLE ====================== -->
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================== PRIMARY BUTTON ====================== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====================== LINK TEXT STYLE ====================== -->
        <Style x:Key="LinkText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FEUGreenDarkBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- ====================== MAIN OUTER CARD ====================== -->
    <Border CornerRadius="18"
            Background="White"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.18" Color="Black"/>
        </Border.Effect>
        <Border.Clip>
            <RectangleGeometry RadiusX="18" RadiusY="18"
                               Rect="0,0,960,620"/>
        </Border.Clip>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- LEFT: Login Form -->
                <ColumnDefinition Width="*"/>
                <!-- RIGHT: Branding Panel with FEUTECH.png logo -->
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ====================== LEFT LOGIN FORM ====================== -->
            <Grid Grid.Column="0">

                <!-- Close Button (top-left) -->
                <Button x:Name="BtnClose"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="16,16,0,0"
                        Width="34" Height="34"
                        Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="closeBorder"
                                    Background="Transparent"
                                    CornerRadius="17"
                                    Width="34" Height="34">
                                <TextBlock Text="✕"
                                           FontSize="14"
                                           Foreground="#9E9E9E"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="closeBorder" Property="Background" Value="#FFEBEE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Login Form Content -->
                <StackPanel VerticalAlignment="Center"
                            Margin="56,0">

                    <!-- Welcome Header -->
                    <TextBlock Text="Welcome Back"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#1B1B1B"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Sign in to your account"
                               FontSize="13"
                               Foreground="#9E9E9E"
                               Margin="0,0,0,20"/>

                    <!-- Role Toggle -->
                    <Border Background="#F0F2F5" CornerRadius="10" Padding="4" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbTeacher" Grid.Column="0"
                                         GroupName="RoleGroup" IsChecked="True"
                                         Checked="RoleToggle_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="roleBorder" Background="Transparent"
                                                CornerRadius="8" Padding="12,10" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon x:Name="roleIcon" Kind="HumanMaleBoard"
                                                                         Width="18" Height="18"
                                                                         Foreground="#9E9E9E"
                                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="roleText" Text="Teacher"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="#9E9E9E"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="roleBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="roleText" Property="Foreground" Value="#1B5E20"/>
                                                <Setter TargetName="roleIcon" Property="Foreground" Value="#1B5E20"/>
                                                <Setter TargetName="roleText" Property="FontWeight" Value="SemiBold"/>
                                                <Setter TargetName="roleBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                            <RadioButton x:Name="RbStudent" Grid.Column="1"
                                         GroupName="RoleGroup"
                                         Checked="RoleToggle_Changed">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="roleBorder" Background="Transparent"
                                                CornerRadius="8" Padding="12,10" Cursor="Hand">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon x:Name="roleIcon" Kind="SchoolOutline"
                                                                         Width="18" Height="18"
                                                                         Foreground="#9E9E9E"
                                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="roleText" Text="Student"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="#9E9E9E"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="roleBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="roleText" Property="Foreground" Value="#1B5E20"/>
                                                <Setter TargetName="roleIcon" Property="Foreground" Value="#1B5E20"/>
                                                <Setter TargetName="roleText" Property="FontWeight" Value="SemiBold"/>
                                                <Setter TargetName="roleBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </Grid>
                    </Border>

                    <!-- Email / Username Field -->
                    <TextBlock Text="Email Address"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#616161"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtLoginEmail"
                             Style="{StaticResource LoginTextBox}"
                             materialDesign:HintAssist.Hint="Enter your email address"
                             Margin="0,0,0,20"/>

                    <!-- Password Field -->
                    <TextBlock Text="Password"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#616161"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="TxtLoginPassword"
                                 Style="{StaticResource LoginPasswordBox}"
                                 materialDesign:HintAssist.Hint="Enter your password"
                                 Margin="0,0,0,10"/>

                    <!-- Forgot Password Link -->
                    <TextBlock HorizontalAlignment="Right"
                               Margin="0,0,0,28"
                               Cursor="Hand"
                               MouseLeftButtonDown="LinkForgotPassword_Click">
                        <Run Text="Forgot Password?"
                             Foreground="#9E9E9E"
                             FontSize="12"
                             Cursor="Hand"/>
                    </TextBlock>

                    <!-- Login Button -->
                    <Button x:Name="BtnLogin"
                            Content="Log In"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnLogin_Click"
                            Margin="0,0,0,28"/>

                    <!-- Divider -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="#E0E0E0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="  OR  " FontSize="11" Foreground="#BDBDBD"/>
                        <Border Grid.Column="2" Height="1" Background="#E0E0E0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Create Account Link -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Don't have an account? "
                                   FontSize="13"
                                   Foreground="#9E9E9E"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="LinkCreateAccount"
                                   Text="Create one here"
                                   Style="{StaticResource LinkText}"
                                   MouseLeftButtonDown="LinkCreateAccount_Click"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ====================== RIGHT BRANDED PANEL with FEUTECH.png LOGO ====================== -->
            <Border Grid.Column="1" CornerRadius="0,18,18,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D3B12" Offset="0"/>
                        <GradientStop Color="#1B5E20" Offset="0.5"/>
                        <GradientStop Color="#2E7D32" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <!-- Decorative Gold Accent Lines -->
                    <Border Opacity="0.06"
                            CornerRadius="0,18,18,0">
                        <Border.Background>
                            <VisualBrush TileMode="Tile" Viewport="0,0,60,60" ViewportUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Grid Width="60" Height="60">
                                        <Line X1="0" Y1="60" X2="60" Y2="0"
                                              Stroke="#FFB300" StrokeThickness="1"/>
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="40">

                        <!-- FEU TECH Logo -->
                        <Border HorizontalAlignment="Center"
                                Margin="0,0,0,30">
                            <Image x:Name="LogoImage"
                                   Source="pack://application:,,,/Assets/FEUTECH.png"
                                   Width="180"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <!-- Gold Divider -->
                        <Border Width="60" Height="3"
                                CornerRadius="2"
                                Background="{StaticResource FEUGoldBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28"/>

                        <!-- Tagline -->
                        <TextBlock Text="FourCUDA"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Anti-Cheating Exam System"
                                   FontSize="13"
                                   Foreground="#A5D6A7"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Empowering Education Through Technology"
                                   FontSize="11"
                                   Foreground="#81C784"
                                   HorizontalAlignment="Center"
                                   FontStyle="Italic"
                                   Opacity="0.8"/>
                    </StackPanel>

                    <!-- Bottom Gold Bar Accent -->
                    <Border VerticalAlignment="Bottom"
                            Height="4"
                            Background="{StaticResource FEUGoldBrush}"
                            Opacity="0.7"
                            CornerRadius="0,0,18,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
