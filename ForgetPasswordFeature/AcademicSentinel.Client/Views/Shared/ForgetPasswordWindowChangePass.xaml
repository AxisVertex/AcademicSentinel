<Window x:Class="AcademicSentinel.Client.Views.Shared.ForgetPasswordWindowChangePass"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Forgot Password - Reset Password"
        Height="640" Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseDown"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>

        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="16" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.16" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Button Width="34" Height="34"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,14,14,0"
                    Click="BtnClose_Click"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0"
                    Content="✕"
                    Foreground="#757575"
                    FontSize="14"/>

            <Border Margin="50"
                    CornerRadius="14"
                    BorderBrush="#EAEAEA"
                    BorderThickness="1"
                    Background="#FCFCFC">
                <Grid>
                    <Border Width="380"
                            Padding="28"
                            Background="White"
                            BorderBrush="#E6E6E6"
                            BorderThickness="1"
                            CornerRadius="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Reset Password"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="#1B1B1B"/>
                            <TextBlock Text="Enter your New Password"
                                       FontSize="13"
                                       Foreground="#757575"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,20"/>

                            <PasswordBox x:Name="TxtNewPassword"
                                         Style="{StaticResource InputPasswordBox}"
                                         Margin="0,0,0,10"/>
                            <PasswordBox x:Name="TxtConfirmPassword"
                                         Style="{StaticResource InputPasswordBox}"
                                         Margin="0,0,0,14"/>

                            <Button Content="Reset Password"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnResetPassword_Click"
                                    Margin="0,0,0,14"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Don't have an account? " Foreground="#707070" FontSize="13"/>
                                <TextBlock Text="Sign up"
                                           FontSize="13"
                                           Foreground="{StaticResource FEUGreenBrush}"
                                           FontWeight="Bold"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="LinkSignUp_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
