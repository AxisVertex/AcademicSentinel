<Window x:Class="AcademicSentinel.Client.Views.SAC.StudentDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Student Dashboard - FourCUDA"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="#1B1B1B"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14">

    <Window.Resources>
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>
        <Color x:Key="FEUGold">#FFB300</Color>
        <Color x:Key="FEUGoldLight">#FFD54F</Color>
        <Color x:Key="FEUGoldDark">#FF8F00</Color>
        <Color x:Key="FEUWhite">#FFFFFF</Color>
        <Color x:Key="FEULightGray">#F0F2F5</Color>
        <Color x:Key="FEUDarkText">#1B1B1B</Color>
        <Color x:Key="FEUSubText">#616161</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="{StaticResource FEUGold}"/>
        <SolidColorBrush x:Key="FEUGoldLightBrush" Color="{StaticResource FEUGoldLight}"/>
        <SolidColorBrush x:Key="FEUGoldDarkBrush" Color="{StaticResource FEUGoldDark}"/>
        <SolidColorBrush x:Key="FEUWhiteBrush" Color="{StaticResource FEUWhite}"/>
        <SolidColorBrush x:Key="FEULightGrayBrush" Color="{StaticResource FEULightGray}"/>
        <SolidColorBrush x:Key="FEUDarkTextBrush" Color="{StaticResource FEUDarkText}"/>
        <SolidColorBrush x:Key="FEUSubTextBrush" Color="{StaticResource FEUSubText}"/>

        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ButtonBorder"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="12"
                                Margin="6,4"
                                Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource FEUGoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="{StaticResource FEUDarkTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="{StaticResource FEUDarkTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUGoldButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGoldBrush}"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGoldLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGoldDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource FEUGreenBrush}"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#0D1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FEUDangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#E53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CourseCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource FEUGreenBrush}"
                CornerRadius="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15" Color="Black" Direction="0"/>
            </Border.Effect>

            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,10" HorizontalAlignment="Center">
                    <Border Width="50" Height="50"
                            CornerRadius="25"
                            Background="White"
                            BorderBrush="{StaticResource FEUGoldBrush}"
                            BorderThickness="2">
                        <Grid>
                            <materialDesign:PackIcon x:Name="SidebarDefaultProfileIcon"
                                                     Kind="AccountCircleOutline"
                                                     Width="28" Height="28"
                                                     Foreground="#9E9E9E"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <Ellipse x:Name="SidebarProfileImage"
                                     Width="44" Height="44"
                                     Visibility="Collapsed"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="SidebarProfileBrush"
                                                Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TxtSidebarStudentName"
                               Text="Student"
                               FontSize="9"
                               Foreground="White"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Width="68"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                    <RadioButton x:Name="BtnProfile"
                                  Style="{StaticResource SidebarButtonStyle}"
                                  GroupName="StudentNav"
                                  Checked="BtnProfile_Checked"
                                  ToolTip="Account Profile">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountCircle"
                                                     Width="28" Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="Profile"
                                       FontSize="9" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="BtnCourses"
                                  Style="{StaticResource SidebarButtonStyle}"
                                  GroupName="StudentNav"
                                  Checked="BtnCourses_Checked"
                                  ToolTip="Room Courses">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="SchoolOutline"
                                                     Width="28" Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="Courses"
                                       FontSize="9" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <RadioButton x:Name="BtnLogout"
                                  Style="{StaticResource SidebarButtonStyle}"
                                  GroupName="StudentNav"
                                  Checked="BtnLogout_Checked"
                                  ToolTip="Logout">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Logout"
                                                     Width="28" Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="Logout"
                                       FontSize="9" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="BtnHelp"
                                  Style="{StaticResource SidebarButtonStyle}"
                                  GroupName="StudentNav"
                                  Checked="BtnHelp_Checked"
                                  ToolTip="Help Guide">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="HelpCircleOutline"
                                                     Width="28" Height="28"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="Help"
                                       FontSize="9" Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="30,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Student Dashboard"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource FEUGreenBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="36" Height="36" Style="{StaticResource FEUOutlineButton}" Padding="0" Click="BtnMinimize_Click" Margin="4,0" ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource FEUOutlineButton}" Padding="0" Click="BtnMaximize_Click" Margin="4,0" ToolTip="Maximize">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"/>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource FEUDangerButton}" Padding="0" Click="BtnClose_Click" ToolTip="Close">
                            <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20,24,24">

                <Grid x:Name="ProfilePanel" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    CornerRadius="16"
                                    Padding="32">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                                </Border.Effect>

                                <StackPanel>
                                    <TextBlock Text="Student Information"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource FEUGreenBrush}"
                                               Margin="0,0,0,24"/>

                                    <Border Background="{StaticResource FEULightGrayBrush}"
                                            CornerRadius="12"
                                            Padding="24"
                                            Margin="0,0,0,28">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Margin="0,0,20,0">
                                                <Border Width="90" Height="90"
                                                        CornerRadius="45"
                                                        Background="#E8E8E8"
                                                        BorderBrush="{StaticResource FEUGreenBrush}"
                                                        BorderThickness="3">
                                                    <Grid>
                                                        <materialDesign:PackIcon x:Name="DefaultProfileIcon"
                                                                                 Kind="AccountCircleOutline"
                                                                                 Width="50" Height="50"
                                                                                 Foreground="#BDBDBD"
                                                                                 HorizontalAlignment="Center"
                                                                                 VerticalAlignment="Center"/>
                                                        <Ellipse x:Name="ProfileImageContainer"
                                                                 Width="84" Height="84"
                                                                 Visibility="Collapsed">
                                                            <Ellipse.Fill>
                                                                <ImageBrush x:Name="ProfileImageBrush"
                                                                            Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtStudentName"
                                                           Text="Student Name"
                                                           FontSize="18" FontWeight="SemiBold"
                                                           Foreground="{StaticResource FEUDarkTextBrush}"
                                                           Margin="0,0,0,8"/>
                                                <Button x:Name="BtnChangePicture"
                                                        Content="Change Picture"
                                                        Style="{StaticResource FEUOutlineButton}"
                                                        Click="BtnChangePicture_Click"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,0,0,6"/>
                                                <TextBlock Text="JPG, PNG (MAX 5MB)"
                                                           FontSize="11"
                                                           Foreground="{StaticResource FEUSubTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Full Name"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource FEUSubTextBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtFullName"
                                             Style="{StaticResource FEUTextBox}"
                                             materialDesign:HintAssist.Hint="Enter New Full Name"
                                             Margin="0,0,0,20"/>

                                    <TextBlock Text="Email Address"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource FEUSubTextBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtEmail"
                                             Style="{StaticResource FEUTextBox}"
                                             materialDesign:HintAssist.Hint="Enter new Email Address"
                                             Margin="0,0,0,28"/>

                                    <Button x:Name="BtnUpdateProfile"
                                            Content="Update Profile"
                                            Style="{StaticResource FEUPrimaryButton}"
                                            Click="BtnUpdateProfile_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    CornerRadius="16"
                                    Padding="32">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                                </Border.Effect>

                                <StackPanel>
                                    <TextBlock Text="Security"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{StaticResource FEUGreenBrush}"
                                               Margin="0,0,0,8"/>

                                    <TextBlock Text="Password"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource FEUDarkTextBrush}"
                                               Margin="0,0,0,20"/>

                                    <TextBlock Text="Current Password"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource FEUSubTextBrush}"
                                               Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtCurrentPassword"
                                                 Style="{StaticResource FEUPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Current Password"
                                                 Margin="0,0,0,16"/>

                                    <TextBlock Text="New Password"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource FEUSubTextBrush}"
                                               Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtNewPassword"
                                                 Style="{StaticResource FEUPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Enter New Password"
                                                 Margin="0,0,0,16"/>

                                    <TextBlock Text="Confirm Password"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource FEUSubTextBrush}"
                                               Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtConfirmPassword"
                                                 Style="{StaticResource FEUPasswordBox}"
                                                 materialDesign:HintAssist.Hint="Confirm Password"
                                                 Margin="0,0,0,28"/>

                                    <Button x:Name="BtnChangePassword"
                                            Content="Change Password"
                                            Style="{StaticResource FEUGoldButton}"
                                            Click="BtnChangePassword_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="CoursesPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            CornerRadius="12"
                            Padding="20,14"
                            Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="My Enrolled Courses"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource FEUGreenBrush}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1"
                                         Orientation="Horizontal">
                                <Button x:Name="BtnRefreshCourses"
                                        Style="{StaticResource FEUOutlineButton}"
                                        Click="BtnRefreshCourses_Click"
                                        Margin="0,0,10,0"
                                        ToolTip="Refresh courses and session status">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh"
                                                                 Width="18" Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnAddCourse"
                                        Style="{StaticResource FEUPrimaryButton}"
                                        Click="BtnAddCourse_Click"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus"
                                                                 Width="18" Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Add" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="BtnDeleteCourse"
                                        Style="{StaticResource FEUDangerButton}"
                                        Click="BtnDeleteCourse_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteOutline"
                                                                 Width="18" Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="StudentCoursesControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CourseCardStyle}"
                                            Width="240" Height="220"
                                            Margin="0,0,16,16"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="CourseCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <CheckBox Grid.Row="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      HorizontalAlignment="Right"
                                                      Margin="0,8,8,0"/>

                                            <Border Grid.Row="1"
                                                    Background="{StaticResource FEULightGrayBrush}"
                                                    CornerRadius="0">
                                                <Grid>
                                                    <Image Source="{Binding CourseImagePath}"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding HasImageVisibility}"/>
                                                    <StackPanel VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Visibility="{Binding HasNoImageVisibility}">
                                                        <materialDesign:PackIcon Kind="BookOpenPageVariantOutline"
                                                                                 Width="48" Height="48"
                                                                                 Foreground="{StaticResource FEUGreenBrush}"
                                                                                 HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border VerticalAlignment="Top"
                                                            HorizontalAlignment="Left"
                                                            Margin="8"
                                                            Background="#CCFFFFFF"
                                                            CornerRadius="8"
                                                            Padding="8,4">
                                                        <TextBlock Text="{Binding CourseLogo}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource FEUSubTextBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Padding="14,12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding CourseDescription}"
                                                               FontSize="13" FontWeight="Medium"
                                                               Foreground="{StaticResource FEUDarkTextBrush}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="36"/>
                                                    <TextBlock Text="{Binding JoinStatusText}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding JoinStatusColor}"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel x:Name="EmptyCoursesState"
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="Visible">
                        <materialDesign:PackIcon Kind="SchoolOutline"
                                                 Width="80" Height="80"
                                                 Foreground="#E0E0E0"
                                                 HorizontalAlignment="Center"/>
                        <TextBlock Text="No Courses Yet"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="#BDBDBD"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,6"/>
                        <TextBlock Text="Click 'Add' to enroll in a course using the code given by your teacher."
                                   FontSize="13"
                                   Foreground="#BDBDBD"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="WaitingRoomPanel" Visibility="Collapsed">
                    <Border Background="White" CornerRadius="16" Padding="32">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <Button Style="{StaticResource FEUOutlineButton}" 
                                        HorizontalAlignment="Left" 
                                        Click="BtnBackToCourses_Click" Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ArrowLeft" Margin="0,0,8,0"/>
                                        <TextBlock Text="Back to Courses"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock x:Name="TxtWaitingRoomTitle" 
                                           Text="Course Title Here" 
                                           FontSize="24" FontWeight="Bold" 
                                           Foreground="{StaticResource FEUGreenBrush}"/>
                                <Separator Margin="0,15"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ClockOutline" Width="80" Height="80" 
                                                         Foreground="{StaticResource FEUGoldBrush}" 
                                                         HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock Text="Waiting for Instructor..." 
                                           FontSize="20" FontWeight="SemiBold" 
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtSessionState" 
                                           Text="Status: Not Joinable Yet" 
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#D32F2F"
                                           Margin="0,10,0,0" TextAlignment="Center"/>
                                <TextBlock x:Name="TxtSessionStateHint"
                                           Text="The session will be joinable as soon as your teacher starts the session." 
                                           Foreground="{StaticResource FEUSubTextBrush}" 
                                           Margin="0,8,0,0" TextAlignment="Center"/>
                                <TextBlock x:Name="TxtRoomDescription"
                                           Text="Description: -"
                                           Foreground="{StaticResource FEUSubTextBrush}"
                                           Margin="0,14,0,0" TextAlignment="Center"/>
                                <TextBlock x:Name="TxtRoomCreatedBy"
                                           Text="Created by: -"
                                           Foreground="{StaticResource FEUSubTextBrush}"
                                           Margin="0,4,0,0" TextAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="BtnJoinSession" Grid.Row="2"
                                    Content="Join Secure Session" 
                                    Style="{StaticResource FEUPrimaryButton}"
                                    Padding="40,15" FontSize="16"
                                    HorizontalAlignment="Center"
                                    Click="BtnJoinSession_Click"/>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Window>