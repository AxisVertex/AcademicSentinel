<Window x:Class="AcademicSentinel.Client.Views.SAC.AddCourseCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Course"
        Height="360" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <SolidColorBrush x:Key="FEUGreenBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="#2E7D32"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
        </Border.Effect>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="BookPlusOutline"
                                             Width="24" Height="24"
                                             Foreground="#1B5E20"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                    <TextBlock Text="Add Course by Code"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1B5E20"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Enter the course code provided by your teacher"
                           FontSize="12" Foreground="#9E9E9E" Margin="34,4,0,0"/>
            </StackPanel>

            <!-- Code Input -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Course Code" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                <TextBox x:Name="TxtCourseCode" Padding="14,12" FontSize="15"
                         BorderBrush="#E0E0E0" BorderThickness="1.5"
                         materialDesign:HintAssist.Hint="e.g. 2TSYS2526"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Cursor="Hand" Margin="0,0,10,0"
                        Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="Transparent"
                                    BorderBrush="#E0E0E0" BorderThickness="1.5"
                                    CornerRadius="8" Padding="24,12" Cursor="Hand"
                                    MinHeight="42">
                                <TextBlock Text="Cancel" FontSize="13" Foreground="#616161"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Cursor="Hand"
                        Click="BtnAdd_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#1B5E20"
                                    CornerRadius="8" Padding="24,12" Cursor="Hand"
                                    MinHeight="42">
                                <TextBlock Text="Add Course" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#2E7D32"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#0D3B12"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
