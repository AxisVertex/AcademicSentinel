<Window x:Class="AcademicSentinel.Client.Views.IMC.CreateCourseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Create New Course"
        Height="461" Width="826"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="28">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Create New Course"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1B5E20"
                       Margin="0,0,0,20"/>

            <!-- Course Name / Description -->
            <TextBlock Text="Course Description"
                       FontSize="13" FontWeight="Medium"
                       Foreground="#616161"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TxtCourseDescription"
                     Padding="14,12"
                     FontSize="14"
                     BorderBrush="#E0E0E0"
                     BorderThickness="1.5"
                     Height="120"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,24"
                     materialDesign:HintAssist.Hint="Enter course name or description"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Cursor="Hand"
                        Click="BtnCancel_Click"
                        Margin="0,0,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="Transparent"
                                    BorderBrush="#E0E0E0" BorderThickness="1.5"
                                    CornerRadius="8" Padding="24,12" Cursor="Hand"
                                    MinHeight="42">
                                <TextBlock Text="Cancel" FontSize="13" Foreground="#616161"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Cursor="Hand"
                        Click="BtnCreate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="#1B5E20"
                                    CornerRadius="8" Padding="24,12" Cursor="Hand"
                                    MinHeight="42">
                                <TextBlock Text="Create Course" FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#2E7D32"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#0D3B12"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
