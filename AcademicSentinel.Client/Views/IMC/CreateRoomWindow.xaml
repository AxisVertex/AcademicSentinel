<Window x:Class="AcademicSentinel.Client.Views.IMC.CreateRoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Create New Room"
        Height="740" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <SolidColorBrush x:Key="FEUGreenBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="#0D3B12"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="#FFB300"/>

        <Style x:Key="RoomTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
        </Border.Effect>

        <!-- ScrollViewer wraps entire content so all fields are visible -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <Grid Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DoorOpen"
                                                     Width="28" Height="28"
                                                     Foreground="#1B5E20"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                            <TextBlock Text="Create New Room"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#1B5E20"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Set up a new course room for your students"
                                   FontSize="13" Foreground="#9E9E9E" Margin="38,6,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Back" Padding="16,8" FontSize="13"
                            Cursor="Hand" VerticalAlignment="Top"
                            Click="BtnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="Transparent"
                                        BorderBrush="#E0E0E0" BorderThickness="1.5"
                                        CornerRadius="8" Padding="16,8" Cursor="Hand">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Room Title Preview -->
                <Border Grid.Row="1" Background="#F0F2F5" CornerRadius="10" Padding="20,16" Margin="0,0,0,24">
                    <TextBlock x:Name="TxtRoomPreview"
                               Text="Room Preview: --"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#1B5E20"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Room Information Form -->
                <StackPanel Grid.Row="2">
                    <Border Height="2" Background="#E8F5E9" CornerRadius="1" Margin="0,0,0,20"/>

                    <TextBlock Text="Room Information" FontSize="16" FontWeight="Bold"
                               Foreground="#1B5E20" Margin="0,0,0,20"/>

                    <!-- Room Subject/Course -->
                    <TextBlock Text="Room Subject / Course" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtRoomSubject" Style="{StaticResource RoomTextBox}"
                             materialDesign:HintAssist.Hint="Enter subject / course"
                             TextChanged="FormField_TextChanged"
                             Margin="0,0,0,18"/>

                    <!-- Section -->
                    <TextBlock Text="Section" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtSection" Style="{StaticResource RoomTextBox}"
                             materialDesign:HintAssist.Hint="Enter section"
                             TextChanged="FormField_TextChanged"
                             Margin="0,0,0,18"/>

                    
                    <!-- Generate Room Code -->
                    <TextBlock Text="Generate Room Code" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="TxtRoomCode" Style="{StaticResource RoomTextBox}"
                                 IsReadOnly="True" Background="#FAFAFA"
                                 FontWeight="SemiBold" FontSize="15"
                                 Foreground="#1B5E20"/>
                        <Button Grid.Column="1" Padding="14,12" FontSize="13" FontWeight="SemiBold"
                                Cursor="Hand" Margin="10,0,0,0"
                                Click="BtnGenerateCode_Click" ToolTip="Generate a new random room code">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" Background="{StaticResource FEUGoldBrush}"
                                            CornerRadius="8" Padding="14,12" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"
                                                                     Foreground="#1B5E20" VerticalAlignment="Center"
                                                                     Margin="0,0,6,0"/>
                                            <TextBlock Text="Generate" Foreground="#1B5E20" FontWeight="SemiBold" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#FFD54F"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background" Value="#FF8F00"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Description (Optional) -->
                    <TextBlock Text="Description (Optional)" FontSize="12" FontWeight="SemiBold" Foreground="#616161" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtDescription" Style="{StaticResource RoomTextBox}"
                             materialDesign:HintAssist.Hint="Brief description of the course"
                             Height="90" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                    <Button Cursor="Hand" Margin="0,0,10,0"
                            Click="BtnCancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="Transparent"
                                        BorderBrush="#E0E0E0" BorderThickness="1.5"
                                        CornerRadius="8" Padding="24,12" Cursor="Hand"
                                        MinHeight="42">
                                    <TextBlock Text="Cancel" FontSize="13" Foreground="#616161"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Create Room" Padding="24,12" FontSize="14" FontWeight="SemiBold"
                            Cursor="Hand" Click="BtnCreateRoom_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="#1B5E20"
                                        CornerRadius="8" Padding="24,12" Cursor="Hand">
                                    <TextBlock Text="Create Room" Foreground="White" FontWeight="SemiBold" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#2E7D32"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#0D3B12"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
