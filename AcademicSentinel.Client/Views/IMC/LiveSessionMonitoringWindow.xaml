<Window x:Class="AcademicSentinel.Client.Views.IMC.LiveSessionMonitoringWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Live Session Monitoring"
        Height="820" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="#1B1B1B"
        TextElement.FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>
        <Color x:Key="FEUGold">#FFB300</Color>
        <Color x:Key="FEULightGray">#F0F2F5</Color>
        <Color x:Key="FEUSubText">#616161</Color>
        <Color x:Key="DangerRed">#D32F2F</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="{StaticResource FEUGold}"/>
        <SolidColorBrush x:Key="FEULightGrayBrush" Color="{StaticResource FEULightGray}"/>
        <SolidColorBrush x:Key="FEUSubTextBrush" Color="{StaticResource FEUSubText}"/>
        <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRed}"/>

        <Style x:Key="EndSessionBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerRedBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,14,24,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="TxtRoomHeader" Text="Live Session Monitoring"
               FontSize="12" Foreground="{StaticResource FEUSubTextBrush}"
               VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" x:Name="TimerPanel" Orientation="Horizontal" Visibility="Collapsed" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="TimerOutline" Width="14" Height="14" Margin="0,0,4,0" 
                                 Foreground="{StaticResource FEUSubTextBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtSessionTimer" Text="Duration: 00:00:00"
                   FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FEUSubTextBrush}"
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource FEUGreenBrush}"
                Margin="20,0,20,0" CornerRadius="12" Padding="24,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="SchoolOutline" Width="32" Height="32"
                                             Foreground="White" Margin="0,0,14,0"/>
                    <StackPanel>
                        <TextBlock Text="Instructor Monitoring Console"
                                   FontSize="17" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="(teacher side)" FontSize="11"
                                   Foreground="#A5D6A7"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2" Content="DEV: Inject Data"
                Background="#FF9800" Foreground="Black" FontWeight="Bold"
                Padding="10,5" Margin="0,0,10,0" Cursor="Hand" BorderThickness="0"
                Click="BtnInjectMockData_Click"/>
                <Button Grid.Column="3" Content="End Session"
                        Style="{StaticResource EndSessionBtn}"
                        Click="BtnEndSession_Click"
                        Margin="0,0,16,0"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="6" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="6" Padding="6">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel HorizontalAlignment="Right" Margin="0,0,12,0">
                        <TextBlock x:Name="TxtProfName" Text="Loading..."
                                   FontWeight="Bold" FontSize="14" Foreground="White"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="FEU Institute of Technology"
                                   FontSize="10" Foreground="#A5D6A7"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Grid Width="40" Height="40">
                        <Border x:Name="TeacherAvatarDefault" Width="40" Height="40" CornerRadius="20" Background="#7C4DFF">
                            <materialDesign:PackIcon Kind="AccountCircle" Width="26" Height="26"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Ellipse x:Name="TeacherAvatarImage" Width="40" Height="40" Visibility="Collapsed">
                            <Ellipse.Fill>
                                <ImageBrush x:Name="TeacherAvatarBrush" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,20,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <Border Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12" Height="148">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" x:Name="TxtMonitoringState" Text="Monitoring: Inactive" 
                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource FEUSubTextBrush}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FFF3E0" CornerRadius="6" Padding="8,6" BorderBrush="#FFCC80" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Countdown" FontSize="10" Foreground="#E65100"/>
                                    <TextBlock x:Name="TxtCountdownDisplay" Text="--:--" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="8,6" BorderBrush="#A5D6A7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Monitoring Timer" FontSize="10" Foreground="#1B5E20"/>
                                    <TextBlock x:Name="TxtMonitoringTimerDisplay" Text="--:--:--" FontSize="16" FontWeight="Bold" Foreground="#1B5E20"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26*"/>
                                <ColumnDefinition Width="95*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="120*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource GhostBtn}" Grid.ColumnSpan="2" Click="BtnViewParticipants_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountMultipleOutline" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Participants"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnSwitchToGlobalLogs" Grid.Column="3" Style="{StaticResource GhostBtn}" Click="BtnShowGlobalLogs_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewHeadline" Width="14" Height="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="Global Logs"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnStartMonitoring" Style="{StaticResource PrimaryBtn}"
                        Padding="16,14" Margin="0,0,0,12"
                        Click="BtnStartMonitoring_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon x:Name="StartStopIcon" Kind="Play" Width="18" Height="18" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStartStopLabel" Text="Start Session Monitoring" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Background="White" CornerRadius="12" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border Background="{StaticResource FEUGreenBrush}" CornerRadius="12,12,0,0" Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountMultiple" Width="16" Height="16"
                                                             Foreground="White" Margin="0,0,6,0"
                                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="Participants" FontSize="13" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource FEUGoldBrush}"
                                        CornerRadius="10" Padding="8,2">
                                    <TextBlock x:Name="TxtParticipantCount" Text="0/0"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource FEUGreenBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="2" x:Name="TxtMissingCount" Text="Missing: 0"
                                           Margin="10,0,0,0"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Padding="12,12,12,6">
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="Magnify"
                                                             Width="14" Height="14" Foreground="#9E9E9E"
                                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Grid.Column="1" x:Name="TxtStudentSearch"
                                             BorderThickness="0" Background="Transparent"
                                             FontSize="12" VerticalContentAlignment="Center"
                                             materialDesign:HintAssist.Hint="Search students..."
                                             TextChanged="TxtStudentSearch_TextChanged"/>
                                </Grid>
                            </Border>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360" Height="340">
                            <Grid>
                                <StackPanel x:Name="EmptyParticipantsState" VerticalAlignment="Center"
                                        HorizontalAlignment="Center" Margin="0,30"
                                        Visibility="Visible">
                                    <materialDesign:PackIcon Kind="AccountMultipleOutline" Width="40" Height="40"
                                                         Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No students connected" FontSize="12" Foreground="#BDBDBD"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Waiting for students to join..." FontSize="10" Foreground="#BDBDBD"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ItemsControl x:Name="StudentsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="row" Padding="10,10" Margin="8,2"
                                                Background="Transparent" CornerRadius="6"
                                                BorderBrush="Transparent" BorderThickness="1.5"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ParticipantRow_Click"
                                                Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0">
                                                        <Border x:Name="DefaultAvatar" CornerRadius="16" Background="#7C4DFF" Visibility="{Binding HasNoProfileImageVisibility}">
                                                            <materialDesign:PackIcon Kind="AccountCircle" Width="20" Height="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse Width="32" Height="32" Visibility="{Binding HasProfileImageVisibility}">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding ProfileImageUrl}" Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Stroke="White" StrokeThickness="1.5"/>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Email}" FontSize="10" Foreground="{StaticResource FEUSubTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="WANTS TO LEAVE"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#E65100"
                                                                   Visibility="{Binding IsLeaveRequested, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{Binding StatusColor}"/>
                                                    </StackPanel>
                                                    <Button x:Name="BtnApproveLeave"
                                                            Grid.Column="3"
                                                            Content="Approve Leave"
                                                            Style="{StaticResource PrimaryBtn}"
                                                            FontSize="10"
                                                            Padding="8,4"
                                                            Margin="6,0,36,0"
                                                            Visibility="{Binding IsLeaveRequested, Converter={StaticResource BoolToVis}}"
                                                            Click="BtnApproveLeave_Click"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <materialDesign:PackIcon Kind="AlertCircle"
                                                                                 Width="16"
                                                                                 Height="16"
                                                                                 Foreground="#E53935"
                                                                                 Margin="0,0,4,0"
                                                                                 Visibility="{Binding HasViolation, Converter={StaticResource BoolToVis}}"/>
                                                        <materialDesign:PackIcon Kind="DesktopClassic"
                                                                                 Width="16"
                                                                                 Height="16"
                                                                                 Foreground="#D32F2F"
                                                                                 Visibility="{Binding HasHardwareViolation, Converter={StaticResource BoolToVis}}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="CriticalAlertBanner"
                            Grid.Row="0"
                            Background="#D32F2F"
                            CornerRadius="8"
                            Padding="10,8"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtCriticalAlertMessage"
                                       Grid.Column="0"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Text="🚨 CRITICAL SECURITY ALERT"/>
                            <Button Grid.Column="1"
                                    Content="Dismiss"
                                    Margin="10,0,0,0"
                                    Padding="10,4"
                                    Background="#33FFFFFF"
                                    Foreground="White"
                                    BorderBrush="#66FFFFFF"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Click="BtnDismissCriticalAlert_Click"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="TxtLogHeader" Text="Global Log Feed"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource FEUGreenBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Border Grid.Column="1" Background="#E8F5E9" CornerRadius="10" Padding="8,3"
                                VerticalAlignment="Center">
                            <TextBlock Text="LIVE UPDATES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource FEUGreenBrush}"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="Filter:" FontSize="12" Foreground="{StaticResource FEUSubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="4" x:Name="CmbLogFilter" Width="140" SelectionChanged="CmbLogFilter_SelectionChanged">
                            <ComboBoxItem Content="All Entries" IsSelected="True"/>
                            <ComboBoxItem Content="Violations Only"/>
                            <ComboBoxItem Content="Connections Only"/>
                        </ComboBox>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel x:Name="EmptyLogFeedState" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,60" Visibility="Visible">
                                <materialDesign:PackIcon Kind="TextBoxOutline" Width="48" Height="48" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                <TextBlock Text="No log entries yet" FontSize="14" FontWeight="SemiBold" Foreground="#BDBDBD" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            </StackPanel>
                            <ItemsControl x:Name="LogFeedItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,10" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ClockOutline" Width="12" Height="12" Foreground="#9E9E9E" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding Timestamp}" FontSize="12" Foreground="{StaticResource FEUSubTextBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                        <TextBlock Text="{Binding StudentEmail}" FontSize="13" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                        <Border Background="{Binding BadgeColor}" CornerRadius="10" Padding="7,2">
                                                            <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap" Foreground="{StaticResource FEUSubTextBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border x:Name="RightDetailPanel" Grid.Column="4" Background="White" CornerRadius="12" Padding="20" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <Grid x:Name="StudentDetailPanel">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Student Details" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FEUSubTextBrush}"/>
                            <Button x:Name="BtnCloseDetailPanel"
                                    Grid.Column="1"
                                    Width="26"
                                    Height="26"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnCloseDetailPanel_Click">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="{StaticResource FEUSubTextBrush}"/>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25" Background="#7C4DFF" Margin="0,0,12,0">
                                <materialDesign:PackIcon Kind="AccountCircle" Width="30" Height="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtSelectedName" Text="Select a Student" FontSize="16" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtSelectedCourse" Text="to view their live status" FontSize="11" Foreground="{StaticResource FEUSubTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse x:Name="SelectedStatusDot" Width="7" Height="7" Fill="#9E9E9E" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSelectedStatus" Text="WAITING" FontSize="9" FontWeight="Bold" Foreground="#9E9E9E"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#EEEEEE" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="ENVIRONMENT PROFILE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Environment: " FontSize="11" Foreground="{StaticResource FEUSubTextBrush}"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Native OS"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUsingVM}" Value="True">
                                                        <Setter Property="Text" Value="Virtual Machine"/>
                                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Remote Access: " FontSize="11" Foreground="{StaticResource FEUSubTextBrush}"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Inactive"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemoteDesktop}" Value="True">
                                                        <Setter Property="Text" Value="Active"/>
                                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="VIOLATION STATISTICS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,8" Height="15"/>
                        <Border Background="#FFEBEE" CornerRadius="8" Padding="16" Margin="0,0,0,20" Height="136">
                            <StackPanel>
                                <TextBlock Text="ALERTS" FontSize="10" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock x:Name="TxtAlertCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock Text="RISK LEVEL" FontSize="10" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock x:Name="TxtRiskLevel" Text="SAFE" FontSize="36" FontWeight="Bold" Foreground="#1B5E20"/>
                            </StackPanel>
                        </Border>
                        <StackPanel x:Name="RecentActivityList" Margin="0,0,0,20"/>

                        <Button Content="Violations Summary"
                                Style="{StaticResource GhostBtn}"
                                HorizontalAlignment="Stretch"
                                Padding="0,10"
                                Margin="0,0,0,10"
                                Click="BtnViewSummary_Click"/>

                        <Button Content="Remove from Session" Style="{StaticResource EndSessionBtn}" HorizontalAlignment="Stretch" Padding="0,12" Click="BtnRemoveFromSession_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="Transparent" Padding="24,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="© 2026 FEU Institute of Technology - Instructor Console" FontSize="11" Foreground="#9E9E9E"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Support" FontSize="11" Foreground="#9E9E9E" Margin="0,0,16,0" Cursor="Hand"/>
                    <TextBlock Text="Documentation" FontSize="11" Foreground="#9E9E9E" Margin="0,0,16,0" Cursor="Hand"/>
                    <TextBlock Text="Privacy Policy" FontSize="11" Foreground="#9E9E9E" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>