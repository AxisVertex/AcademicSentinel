<Window x:Class="AcademicSentinel.Client.Views.IMC.TeacherDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Teacher Dashboard - FourCUDA"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" 
        AllowsTransparency="True" 
        ResizeMode="CanResize"
        MouseLeftButtonDown="Window_MouseDown"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="#1B1B1B"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="7" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ======================== FEU TECH COLOR PALETTE ======================== -->
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>
        <Color x:Key="FEUGold">#FFB300</Color>
        <Color x:Key="FEUGoldLight">#FFD54F</Color>
        <Color x:Key="FEUGoldDark">#FF8F00</Color>
        <Color x:Key="FEUWhite">#FFFFFF</Color>
        <Color x:Key="FEULightGray">#F0F2F5</Color>
        <Color x:Key="FEUDarkText">#1B1B1B</Color>
        <Color x:Key="FEUSubText">#616161</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="{StaticResource FEUGold}"/>
        <SolidColorBrush x:Key="FEUGoldLightBrush" Color="{StaticResource FEUGoldLight}"/>
        <SolidColorBrush x:Key="FEUGoldDarkBrush" Color="{StaticResource FEUGoldDark}"/>
        <SolidColorBrush x:Key="FEUWhiteBrush" Color="{StaticResource FEUWhite}"/>
        <SolidColorBrush x:Key="FEULightGrayBrush" Color="{StaticResource FEULightGray}"/>
        <SolidColorBrush x:Key="FEUDarkTextBrush" Color="{StaticResource FEUDarkText}"/>
        <SolidColorBrush x:Key="FEUSubTextBrush" Color="{StaticResource FEUSubText}"/>

        <!-- ======================== SIDEBAR BUTTON STYLE ======================== -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ButtonBorder" Background="Transparent" CornerRadius="12" Padding="12" Margin="6,4" Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource FEUGoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== TEXT INPUT STYLE ======================== -->
        <Style x:Key="FEUTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="14,12"/><Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/><Setter Property="Foreground" Value="{StaticResource FEUDarkTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/></Trigger>
                            <Trigger Property="IsFocused" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/><Setter TargetName="border" Property="BorderThickness" Value="2"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== PASSWORD BOX STYLE ======================== -->
        <Style x:Key="FEUPasswordBox" TargetType="PasswordBox">
            <Setter Property="Padding" Value="14,12"/><Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1.5"/><Setter Property="Foreground" Value="{StaticResource FEUDarkTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenLightBrush}"/></Trigger>
                            <Trigger Property="IsFocused" Value="True"><Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/><Setter TargetName="border" Property="BorderThickness" Value="2"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== PRIMARY BUTTON (GREEN) ======================== -->
        <Style x:Key="FEUPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/><Setter Property="Cursor" Value="Hand"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== GOLD BUTTON ======================== -->
        <Style x:Key="FEUGoldButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGoldBrush}"/><Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/><Setter Property="Cursor" Value="Hand"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGoldLightBrush}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGoldDarkBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== DANGER BUTTON (RED) ======================== -->
        <Style x:Key="FEUDangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/><Setter Property="Cursor" Value="Hand"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="#E53935"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="#B71C1C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== OUTLINE BUTTON ======================== -->
        <Style x:Key="FEUOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" BorderBrush="{StaticResource FEUGreenBrush}"
                                BorderThickness="1.5" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="btnBorder" Property="Background" Value="#0D1B5E20"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================== COURSE CARD STYLE ======================== -->
        <Style x:Key="CourseCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/><Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Effect"><Setter.Value><DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black"/></Setter.Value></Setter>
        </Style>
    </Window.Resources>

    <!-- ======================== MAIN LAYOUT ======================== -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================== LEFT SIDEBAR ======================== -->
        <Border Grid.Column="0" Background="{StaticResource FEUGreenBrush}" CornerRadius="0,20,20,0">
            <Border.Effect><DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15" Color="Black" Direction="0"/></Border.Effect>
            <DockPanel LastChildFill="False">
                <!-- Teacher Profile Picture (top of sidebar) -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,10" HorizontalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24"
                            Background="#E8E8E8"
                            BorderBrush="{StaticResource FEUGoldBrush}" BorderThickness="2">
                        <Grid>
                            <materialDesign:PackIcon x:Name="SidebarDefaultIcon" Kind="AccountCircle"
                                                     Width="30" Height="30" Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse x:Name="SidebarProfileImage" Width="44" Height="44" Visibility="Collapsed">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="SidebarProfileBrush" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TxtSidebarName" Text="" FontSize="8" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"
                               MaxWidth="60" TextAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                    <RadioButton x:Name="BtnAccountProfile" Style="{StaticResource SidebarButtonStyle}" GroupName="NavGroup" Checked="BtnAccountProfile_Checked" ToolTip="Account Profile">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountCircle" Width="28" Height="28" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Profile" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="BtnRoomCourses" Style="{StaticResource SidebarButtonStyle}" IsChecked="True" GroupName="NavGroup" Checked="BtnRoomCourses_Checked" ToolTip="Room Courses">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="SchoolOutline" Width="28" Height="28" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Courses" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Buttons: Help + Logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <!-- Logout Button -->
                    <RadioButton x:Name="BtnLogout" Style="{StaticResource SidebarButtonStyle}" GroupName="NavGroup" Checked="BtnLogout_Checked" ToolTip="Logout">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Logout" Width="28" Height="28" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Logout" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    <!-- Help Button -->
                    <RadioButton x:Name="BtnHelp" Style="{StaticResource SidebarButtonStyle}" GroupName="NavGroup" Checked="BtnHelp_Checked" ToolTip="Help Guide">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="HelpCircleOutline" Width="28" Height="28" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Help" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ======================== CONTENT AREA ======================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ======================== TOP HEADER BAR ======================== -->
            <Border Grid.Row="0" Background="White" Padding="30,0">
                <Border.Effect><DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="Black"/></Border.Effect>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Teacher Dashboard" FontSize="22" FontWeight="Bold" Foreground="{StaticResource FEUGreenBrush}" VerticalAlignment="Center"/>
                    <!-- Window Controls with MaterialDesign Icons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="36" Height="36" Style="{StaticResource FEUOutlineButton}" Padding="0" Click="BtnMinimize_Click" Margin="4,0" ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource FEUOutlineButton}" Padding="0" Click="BtnMaximize_Click" Margin="4,0" ToolTip="Maximize">
                            <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"/>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource FEUDangerButton}" Padding="0" Click="BtnClose_Click" ToolTip="Close">
                            <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ======================== PAGE CONTENT ======================== -->
            <Grid Grid.Row="1" Margin="24,20,24,24">

                <!-- ========== ACCOUNT PROFILE PANEL ========== -->
                <Grid x:Name="AccountProfilePanel" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: PROFILE INFORMATION -->
                            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="32">
                                <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Profile Information" FontSize="20" FontWeight="Bold" Foreground="{StaticResource FEUGreenBrush}" Margin="0,0,0,24"/>

                                    <!-- Profile Picture Section - Fixed with Ellipse clip -->
                                    <Border Background="{StaticResource FEULightGrayBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,28">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="90" Height="90" CornerRadius="45" Background="#E8E8E8"
                                                    BorderBrush="{StaticResource FEUGreenBrush}" BorderThickness="3" Margin="0,0,20,0">
                                                <Grid>
                                                    <materialDesign:PackIcon x:Name="DefaultProfileIcon" Kind="AccountCircleOutline"
                                                                             Width="50" Height="50" Foreground="#BDBDBD"
                                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <!-- Profile image clipped to circle using Ellipse -->
                                                    <Ellipse x:Name="ProfileImageContainer" Width="84" Height="84" Visibility="Collapsed">
                                                        <Ellipse.Fill>
                                                            <ImageBrush x:Name="ProfileImageBrush" Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="TxtTeacherName" Text="Teacher Name" FontSize="18" FontWeight="SemiBold"
                                                           Foreground="{StaticResource FEUDarkTextBrush}" Margin="0,0,0,8"/>
                                                <Button x:Name="BtnChangePicture" Content="Change Picture" Style="{StaticResource FEUOutlineButton}"
                                                        Click="BtnChangePicture_Click" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                                <TextBlock Text="JPG, PNG (MAX 5MB)" FontSize="11" Foreground="{StaticResource FEUSubTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Full Name" FontSize="13" FontWeight="Medium" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtFullName" Style="{StaticResource FEUTextBox}" materialDesign:HintAssist.Hint="Enter New Full Name" Margin="0,0,0,20"/>

                                    <TextBlock Text="Email Address" FontSize="13" FontWeight="Medium" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtEmail" Style="{StaticResource FEUTextBox}" materialDesign:HintAssist.Hint="Enter new Email Address" Margin="0,0,0,28"/>

                                    <Button x:Name="BtnUpdateProfile" Content="Update Profile" Style="{StaticResource FEUPrimaryButton}" Click="BtnUpdateProfile_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: SECURITY / PASSWORD -->
                            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="32">
                                <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Security" FontSize="20" FontWeight="Bold" Foreground="{StaticResource FEUGreenBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Password" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource FEUDarkTextBrush}" Margin="0,0,0,20"/>

                                    <TextBlock Text="Current Password" FontSize="13" FontWeight="Medium" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtCurrentPassword" Style="{StaticResource FEUPasswordBox}" materialDesign:HintAssist.Hint="Current Password" Margin="0,0,0,16"/>

                                    <TextBlock Text="New Password" FontSize="13" FontWeight="Medium" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtNewPassword" Style="{StaticResource FEUPasswordBox}" materialDesign:HintAssist.Hint="Enter New Password" Margin="0,0,0,16"/>

                                    <TextBlock Text="Confirm Password" FontSize="13" FontWeight="Medium" Foreground="{StaticResource FEUSubTextBrush}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="TxtConfirmPassword" Style="{StaticResource FEUPasswordBox}" materialDesign:HintAssist.Hint="Confirm Password" Margin="0,0,0,28"/>

                                    <Button x:Name="BtnChangePassword" Content="Change Password" Style="{StaticResource FEUGoldButton}" Click="BtnChangePassword_Click" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- ========== ROOM COURSES PANEL ========== -->
                <Grid x:Name="RoomCoursesPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action Bar -->
                    <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,20">
                        <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.06" Color="Black"/></Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="My Courses" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FEUGreenBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnCreateCourse" Style="{StaticResource FEUPrimaryButton}" Click="BtnCreateCourse_Click" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Create" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnDeleteCourse" Style="{StaticResource FEUDangerButton}" Click="BtnDeleteCourse_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Course Cards with checkbox and image -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="CoursesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CourseCardStyle}" Width="240" Height="220" Margin="0,0,16,16" Cursor="Hand"
                                            MouseLeftButtonDown="CourseCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Checkbox for delete selection -->
                                            <CheckBox Grid.Row="0" IsChecked="{Binding IsSelected}" HorizontalAlignment="Right" Margin="0,8,8,0"/>

                                            <!-- Course Image Area -->
                                            <Border Grid.Row="1" Background="{StaticResource FEULightGrayBrush}" CornerRadius="0">
                                                <Grid>
                                                    <!-- Default icon when no image -->
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                Visibility="{Binding HasNoImage, FallbackValue=Visible}">
                                                        <materialDesign:PackIcon Kind="BookOpenPageVariantOutline" Width="48" Height="48"
                                                                                 Foreground="{StaticResource FEUGreenBrush}" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding CourseLogo}" FontSize="12"
                                                                   Foreground="{StaticResource FEUSubTextBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                    <!-- Course image when uploaded -->
                                                    <Image Source="{Binding CourseImagePath}" Stretch="UniformToFill"
                                                           Visibility="{Binding HasImageVisibility, FallbackValue=Collapsed}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Course Description -->
                                            <Border Grid.Row="2" Padding="14,12">
                                                <TextBlock Text="{Binding CourseDescription}" FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource FEUDarkTextBrush}" TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyCoursesState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                        <materialDesign:PackIcon Kind="BookPlusOutline" Width="80" Height="80" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Courses Yet" FontSize="20" FontWeight="SemiBold" Foreground="#BDBDBD" HorizontalAlignment="Center" Margin="0,16,0,6"/>
                        <TextBlock Text="Click 'Create' to add your first course." FontSize="13" Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
