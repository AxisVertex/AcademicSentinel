<Window x:Class="AcademicSentinel.Client.Views.IMC.StudentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Student List"
        Height="620" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F5F5"
        FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.Foreground="#1B1B1B"
        TextElement.FontSize="14">

    <Window.Resources>
        <SolidColorBrush x:Key="FEUGreenBrush" Color="#1B5E20"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="#0D3B12"/>
        <SolidColorBrush x:Key="FEULightGrayBrush" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="FEUSubTextBrush" Color="#616161"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="#FFB300"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource FEUGreenBrush}" BorderThickness="1.5"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0D1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="12" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
        </Border.Effect>

        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TxtRoomTitle"
                           Text=""
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource FEUGreenBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Back"
                        Style="{StaticResource OutlineBtn}"
                        Click="BtnBack_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="AccountMultipleOutline" Width="24" Height="24"
                                             Foreground="{StaticResource FEUGreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Student List" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FEUGreenBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource PrimaryBtn}"
                        Click="BtnAddStudent_Click" Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlusOutline" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Add Student" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="2" Height="2" Background="#E8F5E9" CornerRadius="1" Margin="0,0,0,16"/>

            <Border Grid.Row="3" Background="{StaticResource FEULightGrayBrush}"
                    CornerRadius="6,6,0,0" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Student Id #" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="1" Text="Student Name" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="2" Text="Action" FontWeight="SemiBold" FontSize="13"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Row="4" BorderBrush="#E0E0E0" BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <ItemsControl x:Name="StudentsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,14" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="2.5*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding StudentId}"
                                                       FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding StudentName}"
                                                       FontSize="13" VerticalAlignment="Center"/>
                                            <Button Grid.Column="2" HorizontalAlignment="Center" 
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Padding="10,4"
                                                    Click="BtnActionDropdown_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="DotsVertical" Foreground="#1B5E20" Width="20" Height="20"/>
                                                </StackPanel>
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="remove student" Tag="{Binding}" Click="MenuRemove_Click">
                                                            <MenuItem.Icon>
                                                                <materialDesign:PackIcon Kind="AccountRemove" Width="14" Height="14" Foreground="#D32F2F"/>
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel x:Name="EmptyStudentList" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Margin="0,60" Visibility="Visible">
                            <materialDesign:PackIcon Kind="AccountGroupOutline" Width="56" Height="56"
                                                     Foreground="#E0E0E0"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="No students enrolled yet" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#BDBDBD"
                                       HorizontalAlignment="Center" Margin="0,14,0,4"/>
                            <TextBlock Text="Click 'Add Student' to enroll students to this course room."
                                       FontSize="12" Foreground="#BDBDBD"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="5" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TxtPaginationInfo"
                           Text="Showing 0 of 0 Students"
                           FontSize="12" Foreground="{StaticResource FEUSubTextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" x:Name="PaginationButtons" Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button x:Name="BtnPage1" Content="1" Style="{StaticResource PrimaryBtn}"
                            Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                    <Button x:Name="BtnPage2" Content="2" Style="{StaticResource OutlineBtn}"
                            Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                    <Button x:Name="BtnPage3" Content="3...5" Style="{StaticResource OutlineBtn}"
                            Padding="12,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>