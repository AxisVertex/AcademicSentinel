<Window x:Class="AcademicSentinel.Client.Views.Shared.ForgetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Forgot Password"
        Height="640" Width="980"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseDown"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- FEU Tech Palette -->
        <Color x:Key="FEUGreen">#1B5E20</Color>
        <Color x:Key="FEUGreenLight">#2E7D32</Color>
        <Color x:Key="FEUGreenDark">#0D3B12</Color>
        <Color x:Key="FEUGold">#F2B705</Color>

        <SolidColorBrush x:Key="FEUGreenBrush" Color="{StaticResource FEUGreen}"/>
        <SolidColorBrush x:Key="FEUGreenLightBrush" Color="{StaticResource FEUGreenLight}"/>
        <SolidColorBrush x:Key="FEUGreenDarkBrush" Color="{StaticResource FEUGreenDark}"/>
        <SolidColorBrush x:Key="FEUGoldBrush" Color="{StaticResource FEUGold}"/>

        <LinearGradientBrush x:Key="FEUGreenGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D3B12" Offset="0"/>
            <GradientStop Color="#1B5E20" Offset="0.55"/>
            <GradientStop Color="#2E7D32" Offset="1"/>
        </LinearGradientBrush>

        <!-- Modern web-style input -->
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="CaretBrush" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource FEUGreenBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FEUGreenBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.18" Color="#1B5E20"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource FEUGreenDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Step indicator dot styles -->
        <Style x:Key="StepDotActive" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource FEUGoldBrush}"/>
        </Style>
        <Style x:Key="StepDotInactive" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="#FFFFFF22"/>
            <Setter Property="BorderBrush" Value="#FFFFFF44"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="18" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Opacity="0.20" Color="Black"/>
        </Border.Effect>

        <Border CornerRadius="18" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.85*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: BRAND PANEL -->
                <Border Grid.Column="0" Background="{StaticResource FEUGreenGradient}">
                    <Grid Margin="44,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Brand mark -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{StaticResource FEUGoldBrush}">
                                <TextBlock Text="AS" Foreground="#0D3B12" FontWeight="Bold" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="Academic Sentinel" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                                <TextBlock Text="FEU Tech" Foreground="#FFFFFFB3" FontSize="11" Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Headline + step indicator -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Account Recovery"
                                       Foreground="White"
                                       FontSize="34" FontWeight="SemiBold"
                                       LineHeight="40" TextWrapping="Wrap"/>
                            <TextBlock Text="We'll help you regain access in three quick steps."
                                       Foreground="#FFFFFFCC"
                                       FontSize="13"
                                       Margin="0,12,0,28"
                                       TextWrapping="Wrap"/>

                            <!-- Steps -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,18">
                                <Border Style="{StaticResource StepDotActive}">
                                    <TextBlock Text="1" Foreground="#0D3B12" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Width="40" Height="2" Background="#FFFFFF33" VerticalAlignment="Center" Margin="6,0"/>
                                <Border Style="{StaticResource StepDotInactive}">
                                    <TextBlock Text="2" Foreground="White" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Width="40" Height="2" Background="#FFFFFF33" VerticalAlignment="Center" Margin="6,0"/>
                                <Border Style="{StaticResource StepDotInactive}">
                                    <TextBlock Text="3" Foreground="White" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Step 1 of 3"
                                       Foreground="{StaticResource FEUGoldBrush}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Verify your identity"
                                       Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Enter the email address associated with your account."
                                       Foreground="#FFFFFFB3" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Footer -->
                        <TextBlock Grid.Row="2"
                                   Text="© FEU Institute of Technology — Academic Sentinel"
                                   Foreground="#FFFFFF80" FontSize="10"/>
                    </Grid>
                </Border>

                <!-- RIGHT: FORM PANEL -->
                <Grid Grid.Column="1" Background="White">
                    <Button x:Name="BtnClose"
                            Width="34" Height="34"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,16,16,0"
                            Click="BtnClose_Click"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="✕"
                            Foreground="#9CA3AF"
                            FontSize="14"/>

                    <StackPanel VerticalAlignment="Center" Margin="56,40,56,40">
                        <TextBlock Text="Forgot password?"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock Text="No worries — enter your email and we'll send you a verification code."
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,28"/>

                        <TextBlock Text="Email address"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtEmail"
                                 Style="{StaticResource InputTextBox}"
                                 Margin="0,0,0,20"/>

                        <Button x:Name="BtnSendCode"
                                Content="Send verification code"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnSendCode_Click"
                                Margin="0,0,0,20"/>

                        <Border Background="#F9FAFB" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock Foreground="#6B7280" FontSize="11.5" TextWrapping="Wrap">
                                <Run Text="🔒"/>
                                <Run Text="  Your email is only used to send a one-time secure code. We never share your information."/>
                            </TextBlock>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Don't have an account? " Foreground="#6B7280" FontSize="13"/>
                            <TextBlock Text="Sign up"
                                       FontSize="13"
                                       Foreground="{StaticResource FEUGreenBrush}"
                                       FontWeight="SemiBold"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="LinkSignUp_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
